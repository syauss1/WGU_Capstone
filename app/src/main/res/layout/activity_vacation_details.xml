<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UI.VacationDetails">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingActionButton2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:clickable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/baseline_add_24" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="220dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Vacation Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vacation Title"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/vacationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Bermuda Trip, Spring Break"
                android:inputType="textCapSentences"
                android:importantForAutofill="no" />

            <!-- Hotel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hotel / Accommodation"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/vacationHotel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Hilton Resort"
                android:inputType="textCapSentences"
                android:importantForAutofill="no" />

            <!-- Start Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Start Date"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/vacationStartDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="MM/dd/yyyy"
                android:focusable="false"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:drawableEnd="@android:drawable/ic_menu_my_calendar" />

            <!-- End Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="End Date"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/vacationEndDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="MM/dd/yyyy"
                android:focusable="false"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:drawableEnd="@android:drawable/ic_menu_my_calendar" />

            <!-- Excursions header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Excursions"
                android:textStyle="bold"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Excursion list below the form -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/excursionrecyclerview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/scrollView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
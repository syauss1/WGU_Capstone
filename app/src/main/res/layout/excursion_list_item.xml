<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Colored left accent bar (teal to visually differ from vacation cards) -->
        <View
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:background="#00897B"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Excursion title — ID stays "textView3" to match ExcursionAdapter.java -->
            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Excursion Title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <!-- Excursion date — ID stays "textView4" to match ExcursionAdapter.java -->
            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="13sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Chevron arrow -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_next"
            android:alpha="0.4"
            android:contentDescription="Open excursion"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
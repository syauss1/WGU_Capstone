<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Colored left accent bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:background="#3F51B5"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Vacation title — ID stays "textView2" to match VacationAdapter.java -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vacation Title"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>

            <!-- Date range — ID stays "textViewDates" to match VacationAdapter.java -->
            <TextView
                android:id="@+id/textViewDates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start – End"
                android:textSize="13sp"
                android:textColor="#607D8B"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Chevron arrow -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_next"
            android:alpha="0.4"
            android:contentDescription="Open vacation"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
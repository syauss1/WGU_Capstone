<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".UI.TripReportActivity">

    <!-- Report title -->
    <TextView
        android:id="@+id/reportHeaderTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Trip Report"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Generated timestamp -->
    <TextView
        android:id="@+id/reportGeneratedAt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Generated: --"
        android:textSize="13sp"
        android:textColor="#607D8B"
        app:layout_constraintTop_toBottomOf="@id/reportHeaderTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Search box — filters both vacations and excursions by keyword -->
    <EditText
        android:id="@+id/reportSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Search by title, hotel, or category..."
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@id/reportGeneratedAt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Column headers -->
    <LinearLayout
        android:id="@+id/reportColumnHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        app:layout_constraintTop_toBottomOf="@id/reportSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:text="TYPE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#90A4AE" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:text="TITLE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#90A4AE" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:text="DATE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#90A4AE" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.0"
            android:text="DETAIL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#90A4AE" />

    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/reportEmptyView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No vacations or excursions match your search."
        android:textAlignment="center"
        android:textSize="15sp"
        android:textColor="#90A4AE"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/reportColumnHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reportRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/reportColumnHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
